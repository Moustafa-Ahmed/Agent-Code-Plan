{
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "$id": "./tasks.schema.json",
    "title": "Agent Code Plan Tasks",
    "type": "object",
    "required": ["title", "items"],
    "additionalProperties": true,
    "properties": {
        "title": {
            "type": "string",
            "minLength": 1
        },
        "items": {
            "type": "array",
            "items": {
                "type": "object",
                "required": [
                    "id",
                    "title",
                    "type",
                    "status",
                    "priority",
                    "assignee",
                    "createdAt"
                ],
                "additionalProperties": true,
                "properties": {
                    "id": {
                        "anyOf": [
                            { "type": "integer" },
                            { "type": "string", "minLength": 1 }
                        ]
                    },
                    "title": {
                        "type": "string",
                        "minLength": 1
                    },
                    "description": {
                        "type": "string"
                    },
                    "type": {
                        "type": "string",
                        "enum": ["task", "feature", "bug"]
                    },
                    "status": {
                        "type": "string",
                        "enum": ["Todo", "In Progress", "Done"]
                    },
                    "priority": {
                        "type": "string",
                        "enum": ["low", "medium", "high"]
                    },
                    "assignee": {
                        "type": "string"
                    },
                    "createdAt": {
                        "type": "string",
                        "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
                    }
                }
            }
        }
    }
}
